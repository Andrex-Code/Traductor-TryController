{
  "manifest_version": 3,
  "name": "Traductor iKono PT-BR",
  "version": "0.5.3",
  "description": "Extension para traducir mensajes de iKono Chat entre portugues brasileno y espanol.",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png", "icons/*.jpg", "icons/*.jpeg", "icons/*.webp"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "Traductor iKono",
    "default_popup": "src/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
